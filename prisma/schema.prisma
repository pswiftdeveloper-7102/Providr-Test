// Providr — NDIS provider + support coordination platform
// Tenancy: Org is the tenant boundary. A User can belong to N Orgs.
// Each Org holds zero, one, or both portal entitlements (Provider, SC).
// Hybrid same-org case requires a signed ConflictOfInterestForm.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenancy & identity ────────────────────────────────────────────────

enum Portal {
  PROVIDER
  SC
  // Q8 (2026-05-12): support workers get their own logins to use the
  // Worker App at /app — own roster, voice-to-text notes, incident logging.
  WORKER
}

enum OrgRole {
  OWNER
  ROSTERING_MANAGER
  CARE_MANAGER
  COMPLIANCE_MANAGER
  OFFICE_ADMIN
  SUPPORT_WORKER
  SUPPORT_COORDINATOR
}

model Org {
  id                     String  @id @default(cuid())
  legalName              String
  tradingName            String?
  abn                    String? @unique
  ndisRegistrationNumber String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entitlements           OrgEntitlement[]
  memberships            OrgMembership[]
  conflictOfInterestForm ConflictOfInterestForm?
  complianceContact      OrgComplianceContact?

  participants          Participant[]
  workers               Worker[]
  shifts                Shift[]
  incidents             Incident[]
  carePlans             CarePlan[]
  behaviourSupportPlans BehaviourSupportPlan[]
  restraintRecords      RestraintRecord[]
  trainingRecords       TrainingRecord[]
  externalProviders     ExternalProvider[]
  escalations           Escalation[]
  spendEntries          SpendEntry[]
  communicationLogs     CommunicationLog[]
}

model OrgEntitlement {
  id        String    @id @default(cuid())
  orgId     String
  org       Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  portal    Portal
  active    Boolean   @default(true)
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@unique([orgId, portal])
}

model ConflictOfInterestForm {
  id             String    @id @default(cuid())
  orgId          String    @unique
  org            Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  signedAt       DateTime?
  signedByUserId String?
  documentUrl    String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Q4 (2026-05-12): the NDIS Commission contact that gets pinged on
// reportable incidents (in addition to org admins + the SC). One per org.
model OrgComplianceContact {
  id        String   @id @default(cuid())
  orgId     String   @unique
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  email     String?
  phone     String?  // E.164 — SMS goes here for reportable incidents
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  firstName     String?
  lastName      String?
  phone         String?   // Stored as E.164 (e.g. "+61412345678")
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships          OrgMembership[]
  accounts             Account[]
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
  // Q8: a User may also be a support worker linked through Worker.userId.
  workerProfile        Worker?           @relation("WorkerUser")
}

model OrgMembership {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId    String
  org      Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  roles    OrgRole[]
  joinedAt DateTime  @default(now())

  @@unique([userId, orgId])
}

// ─── Auth.js tables ────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password reset — user requests a reset, we generate a token (hashed
// at rest), they click the link, set a new password. Tokens are single-
// use and expire after 1 hour. In production this would email the link;
// for now the page returns the reset URL inline so it can be copied or
// piped through whichever email transport gets wired up next.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Q8 (2026-05-12): admin invites a Worker to claim a login. The invite
// link carries a one-time token; the worker sets a password (or signs in
// via Google) and the resulting User is linked back via Worker.userId.
model WorkerInvite {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  workerId  String
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  email     String
  expiresAt DateTime
  acceptedAt DateTime?
  createdBy String?
  createdAt DateTime  @default(now())

  @@index([workerId])
}

// ─── Domain — Provider portal MVP entities ─────────────────────────────

model Participant {
  id          String    @id @default(cuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ndisNumber  String?
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  pronouns    String?
  email       String?
  phone       String?
  address     String?
  // Per the upcoming NDIA changes — SC will only serve participants with
  // complex needs. Flag here so the platform is ready when criteria land.
  complexNeeds Boolean  @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plans                 Plan[]
  shifts                Shift[]
  incidents             Incident[]
  serviceAgreements     ServiceAgreement[]
  carePlans             CarePlan[]
  behaviourSupportPlans BehaviourSupportPlan[]
  restraintRecords      RestraintRecord[]
  engagements           ScEngagement[]
  escalations           Escalation[]
  informalSupports      InformalSupport[]
  externalContacts      ExternalContact[]
  communicationLogs     CommunicationLog[]
  workerAccess          WorkerParticipant[]
}

// NDIS plans live under a participant. A plan has a date range and a total
// budget; the budget splits across the three buckets (Core, Capacity,
// Capital). Amounts are stored in cents (AUD) to avoid floating-point
// rounding when tracking spend.
enum PlanStatus {
  DRAFT
  ACTIVE
  EXPIRED
}

enum BudgetCategory {
  CORE
  CAPACITY
  CAPITAL
}

model Plan {
  id             String     @id @default(cuid())
  participantId  String
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  ndisPlanNumber String?
  startDate      DateTime
  endDate        DateTime
  totalCents     Int
  status         PlanStatus @default(ACTIVE)
  // Optional PDF of the original NDIS plan — SC Job 1 ("open Sarah's PDF
  // plan"). Stored via the same `/api/uploads/[key]` route as other files.
  planFileKey    String?
  planFileName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgets PlanBudget[]

  @@index([participantId, status])
}

model PlanBudget {
  id          String         @id @default(cuid())
  planId      String
  plan        Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  category    BudgetCategory
  totalCents  Int
  spentCents  Int            @default(0)

  spendEntries SpendEntry[]

  @@unique([planId, category])
}

// Service agreement between the provider and the participant — Phase 2 of
// the participant lifecycle (Provider Scene B) and one of the compliance
// iceberg artefacts. v1 stores metadata + an optional URL to the signed
// document; file upload to object storage comes later.
enum ServiceAgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model ServiceAgreement {
  id            String                 @id @default(cuid())
  participantId String
  participant   Participant            @relation(fields: [participantId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime?
  signedAt      DateTime?
  // External URL (kept for back-compat — Google Drive / SharePoint links).
  documentUrl   String?
  // Locally-uploaded file: `uploadedFileKey` is the storage filename
  // (UUID + extension), `uploadedFileName` is the original name shown in
  // the UI. Stream the file via /api/uploads/[key] which checks org access.
  uploadedFileKey  String?
  uploadedFileName String?
  notes         String?                @db.Text
  status        ServiceAgreementStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId, status])
}

// Care plan — Phase 3 of the lifecycle. One per participant at a time.
// Goals link supports to outcomes; "Walk to the park — one of Sarah's
// social goals" from Provider Scene C lives here.
enum CarePlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model CarePlan {
  id            String         @id @default(cuid())
  orgId         String
  org           Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  status        CarePlanStatus @default(DRAFT)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  summary       String?        @db.Text

  // Q3 (2026-05-11): support workers must be able to view these — they're
  // the context that makes safe care delivery possible. Free text in v1;
  // can become structured later (e.g. EmergencyContact relation, Risk
  // assessments with severity/likelihood).
  communicationPreferences String? @db.Text
  medicalConditions        String? @db.Text
  allergies                String? @db.Text
  risks                    String? @db.Text
  emergencyContacts        String? @db.Text
  culturalConsiderations   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals Goal[]

  @@index([participantId, status])
}

// Behaviour Support Plan — a distinct clinical document written by a
// behaviour support practitioner (Worker.type = BEHAVIOUR_SUPPORT). Per
// Q3 (2026-05-11), support workers must be able to view this but never
// edit it. Triggers, de-escalation strategies, and "what NOT to do" are
// the operationally critical sections.
enum BSPStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model BehaviourSupportPlan {
  id            String      @id @default(cuid())
  orgId         String
  org           Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  status        BSPStatus   @default(DRAFT)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  authoredById  String?     // Worker.id of the behaviour support practitioner
  summary       String?     @db.Text
  triggers      String?     @db.Text
  deescalation  String?     @db.Text
  whatNotToDo   String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId, status])
}

enum GoalCategory {
  SOCIAL
  PHYSICAL
  COMMUNICATION
  INDEPENDENT_LIVING
  COMMUNITY_PARTICIPATION
  EMPLOYMENT
  OTHER
}

enum GoalStatus {
  IN_PROGRESS
  ACHIEVED
  PAUSED
  DROPPED
}

model Goal {
  id          String       @id @default(cuid())
  carePlanId  String
  carePlan    CarePlan     @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  title       String
  description String?      @db.Text
  category    GoalCategory @default(OTHER)
  status      GoalStatus   @default(IN_PROGRESS)
  targetDate  DateTime?
  // Narrative of what worked, written for the evidence pack — SC Job 6
  // ("show what worked, show what's needed").
  evidenceSummary String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carePlanId, status])
}

// Provider Scene 4 distinguishes three teams: daily helpers (support
// workers), the therapy team (allied health), and the behaviour expert.
// One `Worker` model with a type discriminator covers all three for v1.
enum WorkerType {
  SUPPORT_WORKER
  ALLIED_HEALTH
  BEHAVIOUR_SUPPORT
}

model Worker {
  id        String     @id @default(cuid())
  orgId     String
  org       Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String?    @unique
  user      User?      @relation("WorkerUser", fields: [userId], references: [id], onDelete: SetNull)
  firstName String
  lastName  String
  email     String?
  phone     String?
  type      WorkerType @default(SUPPORT_WORKER)

  // Compliance certificates — used to gate rostering when expired
  ndisWorkerCheckExpiry DateTime?
  firstAidExpiry        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts          Shift[]
  trainingRecords TrainingRecord[]
  invites         WorkerInvite[]
  participantAccess WorkerParticipant[]
}

// 2026-05-14: explicit Worker ↔ Participant access grants. Admins
// pick participants when inviting a worker so the worker knows which
// participants they support. v1 just stores the grant — query-level
// filtering (workers only see shifts/incidents for assigned
// participants) is a follow-up.
model WorkerParticipant {
  id            String      @id @default(cuid())
  workerId      String
  worker        Worker      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  createdById   String?

  @@unique([workerId, participantId])
  @@index([workerId])
  @@index([participantId])
}

enum ShiftStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Shift {
  id             String      @id @default(cuid())
  orgId          String
  org            Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participantId  String
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  workerId       String
  worker         Worker      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  scheduledStart DateTime
  scheduledEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?
  status         ShiftStatus @default(SCHEDULED)
  notes          String?     @db.Text

  // Q1 (2026-05-12): when a hybrid (SC+Provider) org rosters a shift
  // for a participant their own SC team also coordinates, NDIS requires
  // disclosure of the conflict — not prevention. We capture that the
  // admin acknowledged the conflict on the participant's behalf.
  coiAcknowledged   Boolean   @default(false)
  coiAcknowledgedAt DateTime?
  coiAcknowledgedBy String? // User.id of the admin who created the shift

  // Q2 (2026-05-12): expired NDIS Worker Check is a soft block — the
  // admin can proceed by typing an override reason. Both the reason and
  // the timestamp are kept against the shift for audit.
  expiredCheckOverride   String?   @db.Text
  expiredCheckOverrideAt DateTime?
  expiredCheckOverrideBy String? // User.id of the admin who overrode

  // Q8 (2026-05-12): location capture on mobile clock-in/out. lat/lng are
  // browser geolocation values; accuracy is the reported metres radius.
  // Null if the worker declined permission or it was logged from desktop.
  clockInLat        Float?
  clockInLng        Float?
  clockInAccuracyM  Float?
  clockOutLat       Float?
  clockOutLng       Float?
  clockOutAccuracyM Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidents         Incident[]
  progressNotes     ProgressNote[]
  medicationRecords MedicationRecord[]
}

// Free-text shift notes written by the support worker during/after the shift.
// Multiple per shift, timestamped. The end-of-shift "finalise notes" step
// from Provider Scene C is just the final note in this list.
//
// Q4 paperwork-friction #2 (2026-05-11): the end-of-shift handover note is
// flagged separately via `isHandover` so the clock-out flow can prompt for
// it and the next shift can surface it prominently.
enum NoteInputMethod {
  KEYBOARD
  VOICE
}

model ProgressNote {
  id          String           @id @default(cuid())
  shiftId     String
  shift       Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  authorId    String?
  body        String           @db.Text
  isHandover  Boolean          @default(false)
  // Q8 (2026-05-12): voice-to-text-friendly auditing. If the note was
  // captured via the browser SpeechRecognition API we flag it so admins
  // can spot transcription errors when reviewing.
  inputMethod NoteInputMethod  @default(KEYBOARD)
  createdAt   DateTime         @default(now())

  @@index([shiftId, createdAt])
  @@index([shiftId, isHandover])
}

// Medication Administration Record entries — one row per administration
// attempt during a shift, whether the dose was given or not.
//
// Client decisions (2026-05-11):
//   * Same form for PRN and scheduled — `isPrn` flag plus `prnReason` /
//     `prnOutcome` (the latter can be filled in later once the medication
//     takes effect).
//   * Missed doses use a status enum + optional free-text. `missedReason`
//     is required only when status = OTHER; UI enforces that. No automatic
//     escalation logic in v1 — provider policy handles that, system just
//     records what happened.
enum MedicationStatus {
  GIVEN
  REFUSED
  UNAVAILABLE
  OUT_OF_STOCK
  FORGOTTEN
  CLINICAL_HOLD
  OTHER
}

model MedicationRecord {
  id           String           @id @default(cuid())
  shiftId      String
  shift        Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  medication   String
  dose         String?
  givenAt      DateTime
  givenById    String?
  notes        String?          @db.Text
  status       MedicationStatus @default(GIVEN)
  missedReason String?          @db.Text
  isPrn        Boolean          @default(false)
  prnReason    String?          @db.Text
  prnOutcome   String?          @db.Text
  createdAt    DateTime         @default(now())

  @@index([shiftId, givenAt])
}

enum IncidentSeverity {
  MINOR
  MODERATE
  SERIOUS
  REPORTABLE
}

enum IncidentStatus {
  DRAFT
  REPORTED
  UNDER_REVIEW
  CLOSED
}

// 2026-05-13: incident type drives downstream classification + reporting.
// Aligned with the NDIS Commission incident-reporting categories so the
// dropdown values map straight to what regulators expect.
enum IncidentType {
  INJURY
  ABUSE
  NEGLECT
  UNLAWFUL_CONTACT
  UNAUTHORISED_RESTRICTIVE_PRACTICE
  PROPERTY_DAMAGE
  MEDICATION_ERROR
  MISSING_PERSON
  DEATH
  OTHER
}

// Tracks which of the three report-creation flows the incident came in
// through. Used for analytics and for surfacing draft incidents back to
// the supervisor with appropriate UX.
enum IncidentSource {
  QUICK
  AI_ASSISTED
  WIZARD
  AUTO
}

// Restraint use record — Provider Scene D (compliance iceberg) calls these
// out as a distinct artefact. NDIS requires every restraint use to be
// logged, including the type, justification, who authorised it, and what
// happened. Five canonical types in v1; "chemical" is a sensitive area —
// in practice it overlaps with PRN medication on the MAR, so we keep the
// types parallel and let the record cross-reference if needed.
enum RestraintType {
  PHYSICAL
  MECHANICAL
  CHEMICAL
  ENVIRONMENTAL
  SECLUSION
}

model RestraintRecord {
  id              String        @id @default(cuid())
  orgId           String
  org             Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  shiftId         String?
  type            RestraintType
  usedAt          DateTime
  durationMinutes Int?
  reason          String        @db.Text
  outcome         String?       @db.Text
  authorisedById  String?
  createdById     String?
  // Snapshot of the BSP id active at the time, if any — for audit chain
  bspIdAtTime     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId, usedAt])
  @@index([orgId, usedAt])
}

// ─── Support Coordinator domain ────────────────────────────────────────
//
// The SC portal sits at a different level than the Provider portal: the SC
// orchestrates a participant's care ACROSS multiple providers. In our
// tenancy model, the SC's `Org` holds the SC portal entitlement, and the
// SC's `Participant` records are their own — they're not shared with the
// provider orgs the participant uses.
//
// For same-org hybrid customers (one Org has both PROVIDER + SC), the
// participant exists once under that Org and both portals see them.
// For separate-org hybrids and pure SCs, the SC keeps its own record
// (linked to external providers by NDIS number when needed).

// External provider directory — SC Job 2 (Scene B): "find providers" and
// "negotiate rates". This is the SC's address book of providers in their
// network, not other tenant Orgs in our system.
model ExternalProvider {
  id                     String   @id @default(cuid())
  orgId                  String
  org                    Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                   String
  abn                    String?
  ndisRegistrationNumber String?
  serviceCategories      String?  // free text in v1 — comma-separated tags
  rating                 Int?     // 1-5, optional
  capacityStatus         String?  // "accepting" | "waitlist" | "full" — free text v1
  rateNotes              String?  @db.Text
  contactName            String?
  contactEmail           String?
  contactPhone           String?
  notes                  String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagements ScEngagement[]

  @@index([orgId, name])
}

// SC Engagement — SC Job 3 (Scene B): "set up the team". Links a
// participant to an external provider, tracks the lifecycle of that
// relationship (proposed → agreement sent → active → ended/declined).
enum ScEngagementStatus {
  PROPOSED
  AGREEMENT_SENT
  ACTIVE
  ENDED
  DECLINED
}

model ScEngagement {
  id                 String             @id @default(cuid())
  participantId      String
  participant        Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)
  externalProviderId String
  externalProvider   ExternalProvider   @relation(fields: [externalProviderId], references: [id], onDelete: Cascade)
  status             ScEngagementStatus @default(PROPOSED)
  startedAt          DateTime?
  endedAt            DateTime?
  serviceSummary     String?            @db.Text
  notes              String?            @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId, status])
}

// Escalation — SC Job 5 (Scene B): "handle crises". Provider dropped the
// participant, hospital admission, reportable incident across the care
// team, family issue, emergency cover. Distinct from the provider-side
// Incident model (which is hands-on care incidents inside one org's
// shifts).
enum EscalationType {
  PROVIDER_DROP
  HOSPITAL
  REPORTABLE_INCIDENT
  FAMILY_ISSUE
  EMERGENCY_COVER
  PLAN_BREACH
  OTHER
}

enum EscalationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Escalation {
  id            String           @id @default(cuid())
  orgId         String
  org           Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  type          EscalationType
  status        EscalationStatus @default(OPEN)
  openedAt      DateTime         @default(now())
  resolvedAt    DateTime?
  description   String           @db.Text
  resolution    String?          @db.Text
  createdById   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([participantId, openedAt])
}

// Informal supports — Scene A includes family in "the system" the SC
// bridges to. Distinct from the formal `ExternalContact` (NDIA, hospital,
// etc.) and from emergency contacts captured as text on CarePlan.
enum InformalSupportRelationship {
  FAMILY
  FRIEND
  GUARDIAN
  ADVOCATE
  OTHER
}

model InformalSupport {
  id            String                       @id @default(cuid())
  participantId String
  participant   Participant                  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  name          String
  relationship  InformalSupportRelationship  @default(FAMILY)
  phone         String?
  email         String?
  notes         String?                      @db.Text
  isPrimary     Boolean                      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId])
}

// External system contacts — Scene A's "the system": NDIA planner, GP,
// hospital coordinator, housing service, mental health team. Anything
// outside the SC's own org or the providers in the directory.
enum ExternalContactType {
  NDIA_PLANNER
  PLAN_MANAGER
  GP
  HOSPITAL
  ALLIED_HEALTH
  MENTAL_HEALTH
  HOUSING
  EDUCATION
  OTHER
}

model ExternalContact {
  id            String              @id @default(cuid())
  participantId String
  participant   Participant         @relation(fields: [participantId], references: [id], onDelete: Cascade)
  type          ExternalContactType
  organisationName String?
  contactName   String?
  email         String?
  phone         String?
  notes         String?             @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([participantId, type])
}

// Communication log — Scene C's "typical day" opens with a roster-change
// call and includes an OT report arriving, an incident call, plan review
// prep. The SC's day is interrupt-driven; logging touchpoints is part of
// the audit trail.
enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum CommunicationChannel {
  PHONE
  EMAIL
  SMS
  IN_PERSON
  VIDEO
  OTHER
}

model CommunicationLog {
  id            String                  @id @default(cuid())
  orgId         String
  org           Org                     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant             @relation(fields: [participantId], references: [id], onDelete: Cascade)
  occurredAt    DateTime
  direction     CommunicationDirection
  channel       CommunicationChannel
  withParty     String                  // Free text — "Sarah's mum", "OT Jenny", "Acme rostering manager"
  summary       String                  @db.Text
  followUp      String?                 @db.Text
  createdById   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, occurredAt])
  @@index([participantId, occurredAt])
}

// Spend entry — SC Job 4 (Scene B): "watch the money across all
// providers". The SC logs invoices/spend as they arrive from providers
// (or the plan manager). Each entry updates the running total on a
// PlanBudget bucket so the SC can project burn rate across the year.
model SpendEntry {
  id            String         @id @default(cuid())
  orgId         String
  org           Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  planBudgetId  String
  planBudget    PlanBudget     @relation(fields: [planBudgetId], references: [id], onDelete: Cascade)
  occurredAt    DateTime
  amountCents   Int
  description   String         @db.Text
  providerName  String?        // free text — which external provider
  createdById   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planBudgetId, occurredAt])
  @@index([orgId, occurredAt])
}

// Training record — Provider Scene D iceberg explicitly distinguishes
// "training records" from compliance certificates (NDIS Worker Check,
// First Aid). Cert expiry is a hard gate; training is the longer tail of
// ongoing development the org tracks for audit prep.
model TrainingRecord {
  id             String    @id @default(cuid())
  orgId          String
  org            Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workerId       String
  worker         Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  title          String
  provider       String?
  completedAt    DateTime
  expiresAt      DateTime?
  certificateUrl String?
  notes          String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerId, completedAt])
  @@index([orgId, expiresAt])
}

// 24-hour NDIS reportable-incident clock starts at reportedAt (when manager
// is informed). reportedToNdisAt records the actual NDIS submission time
// so we can flag breaches.
model Incident {
  id            String           @id @default(cuid())
  orgId         String
  org           Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participantId String?
  participant   Participant?     @relation(fields: [participantId], references: [id])
  shiftId       String?
  shift         Shift?           @relation(fields: [shiftId], references: [id])
  occurredAt    DateTime
  reportedAt    DateTime?
  severity      IncidentSeverity
  status        IncidentStatus   @default(DRAFT)
  description   String           @db.Text
  immediateActions String?       @db.Text
  reportedToNdisAt DateTime?
  createdById   String?

  // 2026-05-13: extended fields to support the three report flows
  // (Quick / AI-Assisted / Compliance Wizard). Wizard captures all of
  // them; Quick only fills location + type; AI-Assisted populates them
  // from the LLM-structured narrative.
  source              IncidentSource? @default(QUICK)
  incidentType        IncidentType?
  location            String?
  narrativeInput      String?         @db.Text  // raw user text for AI flow
  medicalAttention    Boolean?        @default(false)
  medicalNotes        String?         @db.Text
  restrictivePractice Boolean?        @default(false)
  restrictiveNotes    String?         @db.Text
  witnessNames        String?         @db.Text
  declarationName     String?
  declarationSignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}