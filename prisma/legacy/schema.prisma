// READ-ONLY SOURCE schema for the legacy Laravel-shaped database.
// This file exists solely so the migration script (scripts/migrate-from-laravel.ts)
// has a typed Prisma client to read from. NEVER use this client to write —
// the legacy DB is the production system, and the new app should never touch
// it. The migration script writes to the *target* DB via the main Prisma client.
//
// Generated client lives at node_modules/@prisma/client-legacy (out of band
// from the main client at node_modules/@prisma/client) so the two never clash.
// LEGACY_DATABASE_URL points at a copy of the live DB restored to a staging
// Postgres — NEVER point it at the actual live DB.

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client-legacy"
}

datasource db {
  provider = "postgresql"
  url      = env("LEGACY_DATABASE_URL")
}

model admin_dashboard_preferences {
  id           BigInt    @id @default(autoincrement())
  admin_id     BigInt    @unique(map: "admin_dashboard_preferences_admin_id_unique")
  layout       Json?     @db.Json
  hidden_tiles Json?     @db.Json
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  admins       admins    @relation(fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "admin_dashboard_preferences_admin_id_foreign")
}

model admins {
  id                          BigInt                       @id @default(autoincrement())
  name                        String                       @db.VarChar(255)
  email                       String                       @unique(map: "admins_email_unique") @db.VarChar(255)
  password                    String                       @db.VarChar(255)
  created_at                  DateTime?                    @db.Timestamp(0)
  updated_at                  DateTime?                    @db.Timestamp(0)
  admin_dashboard_preferences admin_dashboard_preferences?
  provider_company_imports    provider_company_imports[]
}

