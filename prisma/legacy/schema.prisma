  default_charge_item String?
  notes               String?
  created_at          DateTime?         @db.Timestamp(0)
  updated_at          DateTime?         @db.Timestamp(0)
  participants        participants      @relation(fields: [participant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  participant_plans   participant_plans @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([participant_id], map: "idx_plan_services_pid")
  @@index([plan_id], map: "idx_plan_services_plan_id")
}

model participant_alerts {
  id             BigInt       @id @default(autoincrement())
  participant_id BigInt
  title          String       @db.VarChar(255)
  description    String?
  severity       String       @default("info") @db.VarChar(20)
  is_active      Boolean      @default(true)
  created_by_id  BigInt?
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  updated_at     DateTime?    @db.Timestamp(6)
  users          users?       @relation(fields: [created_by_id], references: [id], onUpdate: NoAction)
  participants   participants @relation(fields: [participant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([participant_id], map: "idx_participant_alerts_pid")
}

model participant_risks {
  id                  BigInt       @id @default(autoincrement())
  participant_id      BigInt
  title               String       @db.VarChar(255)
  category            String?      @db.VarChar(100)
  description         String?
  likelihood          String       @db.VarChar(20)
  consequence         String       @db.VarChar(20)
  risk_level          String?      @db.VarChar(20)
  mitigation_strategy String?
  review_date         DateTime?    @db.Date
  status              String       @default("active") @db.VarChar(50)
  created_by_id       BigInt?
  created_at          DateTime?    @default(now()) @db.Timestamp(6)
  updated_at          DateTime?    @db.Timestamp(6)
  users               users?       @relation(fields: [created_by_id], references: [id], onUpdate: NoAction)
  participants        participants @relation(fields: [participant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([participant_id], map: "idx_participant_risks_pid")
}

model ai_usage_logs {
  id                  BigInt              @id @default(autoincrement())
  provider_company_id BigInt?
  ai_model_id         BigInt?
  purpose             String?             @db.VarChar(50)
  input_tokens        Int?                @default(0)
  output_tokens       Int?                @default(0)
  estimated_cost_usd  Decimal?            @default(0) @db.Decimal(10, 6)
  reference_id        BigInt?
  reference_type      String?             @db.VarChar(50)
  created_at          DateTime?           @default(now()) @db.Timestamptz(6)
  ai_models           ai_models?          @relation(fields: [ai_model_id], references: [id], onUpdate: NoAction)
  provider_companies  provider_companies? @relation(fields: [provider_company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_ai_usage_logs_created")
  @@index([provider_company_id], map: "idx_ai_usage_logs_provider")
}

model subscription_ai_limits {
  id                     BigInt           @id @default(autoincrement())
  stripe_product_id      BigInt?          @unique
  ai_model_id            BigInt?
  monthly_incident_limit Int?
  monthly_cost_limit_usd Decimal?         @db.Decimal(10, 2)
  overage_action         String?          @default("block") @db.VarChar(20)
  created_at             DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?        @default(now()) @db.Timestamptz(6)
  ai_models              ai_models?       @relation(fields: [ai_model_id], references: [id], onUpdate: NoAction)
  stripe_products        stripe_products? @relation(fields: [stripe_product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// SC (Support Coordinator) organisation — the SC's business entity
model sc_organisations {
  id                    BigInt                  @id @default(autoincrement())
  name                  String                  @db.VarChar(255)
  abn                   String?                 @db.VarChar(50)
  contact_email         String                  @db.VarChar(255)
  is_active             Boolean                 @default(true)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  evidence_packs        evidence_packs[]
  sc_participant_access sc_participant_access[]
  sc_provider_access    sc_provider_access[]
  sc_users              sc_users[]
}

/// Individual SC user — login credentials + link to SC org
model sc_users {
  id               BigInt           @id @default(autoincrement())
  sc_org_id        BigInt
  email            String           @unique(map: "sc_users_email_unique") @db.VarChar(255)
  password         String           @db.VarChar(255)
  first_name       String           @db.VarChar(255)
  last_name        String?          @db.VarChar(255)
  phone            String?          @db.VarChar(255)
  is_active        Boolean          @default(true)
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?        @default(now()) @db.Timestamptz(6)
  role             String           @default("member") @db.VarChar(20)
  evidence_packs   evidence_packs[]
  sc_organisations sc_organisations @relation(fields: [sc_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sc_org_id], map: "idx_sc_users_sc_org")
}

/// Top-level consent: SC org has been granted access to a provider's data
model sc_provider_access {
  id                    BigInt                  @id @default(autoincrement())
  sc_org_id             BigInt?
  provider_company_id   BigInt
  invited_by_user_id    BigInt
  invitation_token      String?                 @db.VarChar(255)
  invitation_expires_at DateTime?               @db.Timestamptz(6)
  invitation_email      String?                 @db.VarChar(255)
  invitation_note       String?
  status                String                  @default("pending") @db.VarChar(20)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  sc_participant_access sc_participant_access[]
  provider_companies    provider_companies      @relation(fields: [provider_company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sc_organisations      sc_organisations?       @relation(fields: [sc_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sc_org_id, provider_company_id], map: "idx_sc_provider_access_org_provider")
  @@index([provider_company_id], map: "idx_sc_provider_access_provider")
}

/// Per-participant access grant — what RLS/app-layer reads
model sc_participant_access {
  id                    BigInt             @id @default(autoincrement())
  sc_org_id             BigInt
  sc_provider_access_id BigInt
  participant_id        BigInt
  provider_company_id   BigInt
  access_type           String             @default("read") @db.VarChar(20)
  granted_at            DateTime?          @default(now()) @db.Timestamptz(6)
  expires_at            DateTime?          @db.Timestamptz(6)
  revoked_at            DateTime?          @db.Timestamptz(6)
  participants          participants       @relation(fields: [participant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  provider_companies    provider_companies @relation(fields: [provider_company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sc_organisations      sc_organisations   @relation(fields: [sc_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sc_provider_access    sc_provider_access @relation(fields: [sc_provider_access_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sc_org_id], map: "idx_sc_participant_access_org")
  @@index([participant_id], map: "idx_sc_participant_access_participant")
  @@index([provider_company_id], map: "idx_sc_participant_access_provider")
}

/// Evidence packs generated by the Evidence Engine for NDIS plan reviews
model evidence_packs {
  id                    BigInt             @id @default(autoincrement())
  participant_id        BigInt
  provider_id           BigInt
  sc_org_id             BigInt
  created_by_sc_user_id BigInt
  status                String             @default("draft") @db.VarChar(20)
  ai_model_used         String?            @db.VarChar(100)
  ai_json_output        Json?
  edited_json_output    Json?
  pdf_storage_path      String?            @db.VarChar(500)
  incident_ids_used     BigInt[]
  generation_error      String?
  created_at            DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?          @default(now()) @db.Timestamptz(6)
  sc_users              sc_users           @relation(fields: [created_by_sc_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  participants          participants       @relation(fields: [participant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  provider_companies    provider_companies @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sc_organisations      sc_organisations   @relation(fields: [sc_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([participant_id], map: "idx_evidence_packs_participant")
  @@index([provider_id], map: "idx_evidence_packs_provider")
  @@index([sc_org_id], map: "idx_evidence_packs_sc_org")
  @@index([created_by_sc_user_id], map: "idx_evidence_packs_sc_user")
}

model incident_notifications {
  id                     BigInt    @id @default(autoincrement())
  incident_id            BigInt
  notification_type      String    @db.VarChar(50)
  notification_form_type String?   @db.VarChar(20)
  recipient_user_id      BigInt?
  recipient_email        String?   @db.VarChar(255)
  sent_at                DateTime? @db.Timestamptz(6)
  deadline_at            DateTime? @db.Timestamptz(6)
  status                 String    @default("pending") @db.VarChar(20)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @db.Timestamptz(6)
  incidents              incidents @relation(fields: [incident_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  users?    @relation(fields: [recipient_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([incident_id], map: "idx_incident_notifications_incident_id")
  @@index([status], map: "idx_incident_notifications_status")
}

model ui_badge_configs {
  id            BigInt    @id @default(autoincrement())
  domain        String    @db.VarChar(50)
  value         String    @db.VarChar(50)
  label         String    @db.VarChar(100)
  badge_variant String    @db.VarChar(30)
